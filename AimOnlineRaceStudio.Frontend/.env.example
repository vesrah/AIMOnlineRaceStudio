# Backend API base URL (no trailing slash). Example: http://localhost:5001
NEXT_PUBLIC_API_URL=http://localhost:5001

# Optional: set to "true" to proxy /api/* to NEXT_PUBLIC_API_URL in dev (avoids CORS).
# When true, the frontend will request /api/... on the same origin and Next.js rewrites to the backend.
# NEXT_PUBLIC_USE_API_PROXY=true
